# Integration test credentials.
#
# Copy this file to tests/.env and fill in the providers you want to test.
# The bootstrap loads it automatically; real environment variables take
# precedence. Tests for providers without credentials are skipped.
#
# Encryption: tls | starttls | none (default tls)

# --- Gmail (imap.gmail.com) ---
#IMAP_GMAIL_HOST=imap.gmail.com
#IMAP_GMAIL_PORT=993
#IMAP_GMAIL_USER=
#IMAP_GMAIL_PASS=
#IMAP_GMAIL_ENCRYPTION=tls

# --- Outlook / Office 365 (outlook.office365.com) ---
#IMAP_OUTLOOK_HOST=outlook.office365.com
#IMAP_OUTLOOK_PORT=993
#IMAP_OUTLOOK_USER=
#IMAP_OUTLOOK_PASS=
#IMAP_OUTLOOK_ENCRYPTION=tls

# --- iCloud (imap.mail.me.com) ---
#IMAP_ICLOUD_HOST=imap.mail.me.com
#IMAP_ICLOUD_PORT=993
#IMAP_ICLOUD_USER=
#IMAP_ICLOUD_PASS=
#IMAP_ICLOUD_ENCRYPTION=tls

# --- Yahoo (imap.mail.yahoo.com) ---
#IMAP_YAHOO_HOST=imap.mail.yahoo.com
#IMAP_YAHOO_PORT=993
#IMAP_YAHOO_USER=
#IMAP_YAHOO_PASS=
#IMAP_YAHOO_ENCRYPTION=tls

