{
  "name": "d4ry/imap-client",
  "license": "Apache-2.0",
  "description": "Socketbased IMAP Client for PHP ",
  "autoload": {
    "psr-4": {
      "D4ry\\ImapClient\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "D4ry\\ImapClient\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "D4ryB3rry",
      "email": "d4ryb3rry@gmail.com"
    }
  ],
  "require": {
    "ext-mbstring": "*",
    "ext-openssl": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.0",
    "infection/infection": "^0.32.6"
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit --testsuite unit",
    "test:integration": "phpunit --testsuite integration",
    "test:coverage": "phpunit --coverage-html build/coverage/html --coverage-text",
    "test:coverage:unit": "phpunit --testsuite unit --coverage-html build/coverage/html --coverage-text",
    "infection": "infection --threads=max --show-mutations",
    "infection:ci": "infection --threads=max --logger-github --no-progress"
  },
  "config": {
    "allow-plugins": {
      "infection/extension-installer": true
    }
  }
}
