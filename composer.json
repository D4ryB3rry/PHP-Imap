{
  "name": "d4ry/imap-client",
  "license": "Apache-2.0",
  "description": "Socketbased IMAP Client for PHP ",
  "autoload": {
    "psr-4": {
      "D4ry\\ImapClient\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "D4ry\\ImapClient\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "D4ryB3rry",
      "email": "d4ryb3rry@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.0",
    "ext-mbstring": "*",
    "ext-openssl": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "infection/infection": "^0.25"
  },
  "extra": {
    "branch-alias": {
      "dev-php8.0-compability": "0.1.x-dev"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit --testsuite unit",
    "test:integration": "phpunit --testsuite integration",
    "infection": "infection --threads=max --show-mutations",
    "infection:ci": "infection --threads=max --no-progress"
  },
  "config": {
    "allow-plugins": {
      "infection/extension-installer": true
    }
  }
}
